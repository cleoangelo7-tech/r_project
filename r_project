    "svd_results = []\n",
    "\n",
    "for n in factors_to_try:\n",
    "    start = time.time()\n",
    "    \n",
    "    train_matrix = train_ratings.pivot_table(index='userId', columns='movieId', values='rating')\n",
    "    train_means = train_matrix.mean(axis=1)\n",
    "    train_centered = train_matrix.sub(train_means, axis=0).fillna(0)\n",
    "    \n",
    "    svd = TruncatedSVD(n_components=n, random_state=42)\n",
    "    user_factors = svd.fit_transform(train_centered)\n",
    "    reconstructed = pd.DataFrame(\n",
    "        np.dot(user_factors, svd.components_),\n",
    "        index=train_centered.index, columns=train_centered.columns\n",
