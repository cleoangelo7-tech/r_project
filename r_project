    "# Evaluate KNN RMSE on held-out ratings\n",
    "def evaluate_knn(ratings_df, matrix, movie_map, movie_inv_map, k=20, sample_n=10000):\n",
    "    \"\"\"Predict held-out ratings using weighted average of K nearest neighbor items.\"\"\"\n",
    "    np.random.seed(42)\n",
    "    test = ratings_df[np.random.random(len(ratings_df)) < 0.2]\n",
    "    if len(test) > sample_n:\n",
    "        test = test.sample(n=sample_n, random_state=42)\n",
    "    \n",
    "    knn = NearestNeighbors(n_neighbors=k+1, metric='cosine', algorithm='brute')\n",
    "    knn.fit(matrix)\n",
    "    \n",
    "    actuals, preds, skipped = [], [], 0\n",
    "    \n",
    "    for _, row in test.iterrows():\n",
    "        uid, mid, actual = row['userId'], row['movieId'], row['rating']\n",
    "        if mid not in movie_map:\n",
    "            skipped += 1\n",
    "            continue\n",
    "        \n",
    "        distances, indices = knn.kneighbors(matrix[movie_map[mid]].reshape(1, -1))\n",
    "        w_sum, s_sum = 0, 0\n",
    "        \n",
    "        for i in range(1, len(indices[0])):\n",
    "            sim = 1 - distances[0][i]\n",
    "            if sim <= 0:\n",
    "                continue\n",
    "            neighbor_id = movie_inv_map[indices[0][i]]\n",
    "            ur = ratings_df[(ratings_df['userId'] == uid) & (ratings_df['movieId'] == neighbor_id)]['rating']\n",
    "            if len(ur) > 0:\n",
    "                w_sum += sim * ur.values[0]\n",
    "                s_sum += sim\n",
    "        \n",
    "        if s_sum > 0:\n",
    "            actuals.append(actual)\n",
    "            preds.append(w_sum / s_sum)\n",
    "        else:\n",
    "            skipped += 1\n",
    "    \n",
    "    rmse = np.sqrt(mean_squared_error(actuals, preds))\n",
    "    mae = mean_absolute_error(actuals, preds)\n",
    "    print(f\"KNN — RMSE: {rmse:.4f} | MAE: {mae:.4f} | Predictions: {len(actuals):,} | Skipped: {skipped:,}\")\n",
    "    return {'rmse': rmse, 'mae': mae}\n",
    "\n",
    "print(\"Evaluating KNN (may take a few minutes)...\")\n",
    "start = time.time()\n",
