    "# Train final model and generate per-user recommendations\n",
    "best_n = int(svd_df.loc[svd_df['rmse'].idxmin(), 'n_factors'])\n",
    "svd_final = TruncatedSVD(n_components=best_n, random_state=42)\n",
    "user_factors_final = svd_final.fit_transform(user_movie_centered)\n",
    "\n",
    "predictions_matrix = pd.DataFrame(\n",
    "    np.dot(user_factors_final, svd_final.components_),\n",
    "    index=user_movie_centered.index, columns=user_movie_centered.columns\n",
    ").add(user_means, axis=0).clip(0.5, 5.0)\n",
    "\n",
    "def get_svd_recommendations(user_id, n=10):\n",
    "    \"\"\"Get personalized recommendations for a user from SVD latent factors.\"\"\"\n",
    "    if user_id not in predictions_matrix.index:\n",
    "        return None\n",
    "    \n",
    "    rated = set(ratings_cf[ratings_cf['userId'] == user_id]['movieId'])\n",
    "    unrated = [m for m in predictions_matrix.columns if m not in rated]\n",
    "    preds = predictions_matrix.loc[user_id, unrated].sort_values(ascending=False).head(n)\n",
    "    \n",
    "    results = []\n",
    "    for mid, pred in preds.items():\n",
    "        info = movies[movies['movieId'] == mid]\n",
    "        if len(info) > 0:\n",
    "            results.append({'title': info.iloc[0]['title'], 'genres': info.iloc[0]['genres'], 'predicted_rating': round(pred, 2)})\n",
    "    \n",
    "    df = pd.DataFrame(results)\n",
    "    df.index = range(1, len(df)+1)\n",
    "    return df\n",
    "\n",
    "# Show recommendations for 3 active users with their top-rated movies for context\n",
    "sample_users = ratings_cf['userId'].value_counts().head(3).index.tolist()\n",
    "for uid in sample_users:\n",
    "    top = ratings_cf[ratings_cf['userId'] == uid].nlargest(5, 'rating').merge(movies, on='movieId')\n",
    "    print(f\"\\nUser {uid} — top rated: {', '.join(top['title'].values[:3])}\")\n",
    "    display(get_svd_recommendations(uid, n=10))"
   ]
  },
