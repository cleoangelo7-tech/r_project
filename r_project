    "def get_content_recommendations(title, cosine_sim=cosine_sim, movies_df=movies_cb, n=10):\n",
    "    \"\"\"Find top-N similar movies using cosine similarity on TF-IDF genre/tag vectors.\"\"\"\n",
    "    idx_matches = movies_df[movies_df['title'].str.contains(title, case=False, na=False)]\n",
    "    if len(idx_matches) == 0:\n",
    "        print(f\"Movie '{title}' not found.\")\n",
    "        return None\n",
    "    \n",
    "    idx = idx_matches.index[0]\n",
