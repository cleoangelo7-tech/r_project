   "source": [
    "# Build TF-IDF feature vectors from genres + tags\n",
    "movies_cb = movies.copy()\n",
    "movies_cb['genre_features'] = movies_cb['genres'].str.replace('|', ' ')\n",
    "\n",
    "if tags is not None:\n",
    "    movie_tags = tags.groupby('movieId')['tag'].apply(\n",
    "        lambda x: ' '.join(x.astype(str).str.lower())\n",
    "    ).reset_index()\n",
    "    movies_cb = movies_cb.merge(movie_tags, on='movieId', how='left')\n",
    "    movies_cb['tag'] = movies_cb['tag'].fillna('')\n",
    "    movies_cb['features'] = movies_cb['genre_features'] + ' ' + movies_cb['tag']\n",
    "else:\n",
    "    movies_cb['features'] = movies_cb['genre_features']\n",
    "\n",
    "tfidf = TfidfVectorizer(stop_words='english', max_features=1000)\n",
    "tfidf_matrix = tfidf.fit_transform(movies_cb['features'])\n",
    "cosine_sim = cosine_similarity(tfidf_matrix, tfidf_matrix)\n",
    "\n",
    "print(f\"TF-IDF matrix: {tfidf_matrix.shape} | Similarity matrix: {cosine_sim.shape}\")"
   ]
